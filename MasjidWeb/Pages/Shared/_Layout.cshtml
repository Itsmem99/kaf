<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - كاف</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/kaf.styles.css" asp-append-version="true" />
</head>

<body class="tech-pink">

    <header class="main-header">
        <nav class="navbar navbar-expand-lg">
            <div class="container">

                <!-- اسم الموقع -->
                <a class="navbar-brand" asp-page="/Index">
                    🤖 كاف
                </a>

                <!-- زر الموبايل -->
                <button class="navbar-toggler" type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#mainNavbar"
                        aria-controls="mainNavbar"
                        aria-expanded="false"
                        aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <!-- القائمة -->
                <div class="collapse navbar-collapse" id="mainNavbar">
                    <ul class="navbar-nav ms-auto mb-2 mb-lg-0">

                        <li class="nav-item">
                            <a class="nav-link" asp-page="/Index">الرئيسية</a>
                        </li>

                        

                        <li class="nav-item">
                            <a class="nav-link" asp-page="/Books/Categories">التصنيفات</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-page="/Books/NewReleases">الإصدارات الجديدة</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-page="/About">عنّي</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-page="/Contact">تواصل</a>
                        </li>

                    </ul>
                </div>

            </div>
        </nav>
    </header>

    <div class="container my-4">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top text-muted py-3 mt-5">
        <div class="container text-center">
            &copy; 2025 - كاف | منصة ذكية لعرض الكتب ✨🤖
        </div>
    </footer>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
