@page
@model kaf.Pages.ContactModel
@{
}

<div class="container my-5 text-center">
    <h2 class="mb-4">تواصل</h2>

    <p class="mb-4">
        إذا وجدت نفسك في كلماتي،  
        أو رغبت بمشاركة شعور…  
        يسعدني أن أسمع منك 🤍
    </p>

    <form class="contact-form mx-auto">

        <input type="text" class="form-control mb-3"
               placeholder="اسمك" />

        <input type="email" class="form-control mb-3"
               placeholder="بريدك الإلكتروني" />

        <textarea class="form-control mb-3"
                  rows="4"
                  placeholder="رسالتك"></textarea>

        <button type="submit" class="btn btn-pink">
            إرسال ✨
        </button>

    </form>
</div>
<div class="comments-section my-5">

    <h4 class="mb-3">💬 كلمات الزوّار</h4>

    <textarea id="commentInput" placeholder="اكتب جملة… واتركها هنا 🤍"></textarea>

    <div class="text-end mt-2">
        <button class="btn btn-pink" onclick="addComment()">أرسل</button>
    </div>

    <p class="mt-3 text-muted">
        عدد الكلمات: <span id="commentCount">0</span>
    </p>

    <div id="commentsList"></div>

</div>
